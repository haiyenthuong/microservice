                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"Password123!\",\n  \"confirmPassword\": \"Password123!\",\n  \"fullname\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"mobile\": \"0123456789\",\n  \"address\": \"Ho Chi Minh City\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/auth/register",
                  "host": ["{{baseUrl}}"],
                  "path": ["auth", "register"],
                  "query": []
